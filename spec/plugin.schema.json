{
  "$id": "https://sensecraft.seeed.cc/spec/plugin.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "contract_version": 1,
  "properties": {
    "author": {
      "type": "string"
    },
    "backend": {
      "additionalProperties": true,
      "properties": {
        "module": {
          "description": "Python module path of the backend router.",
          "type": "string"
        },
        "websocket": {
          "description": "Whether the backend exposes a WebSocket.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "contributes": {
      "additionalProperties": true,
      "description": "Extension points a plugin contributes to the host engine. Registered at runtime by plugin_manager on enable.",
      "properties": {
        "deployers": {
          "description": "Custom deploy/verify step types contributed by this plugin. Registered as '<plugin-id>/<type>' in the plugin deployer view (NOT in the built-in contract). See services/plugin_manager.py registration hook.",
          "items": {
            "additionalProperties": true,
            "properties": {
              "category": {
                "description": "Step category. verify = no-op backend + interactive frontend renderer.",
                "enum": [
                  "deploy",
                  "verify"
                ],
                "type": "string"
              },
              "module": {
                "description": "Importable deployer class, e.g. 'backend.deployer:MyDeployer'. Must subclass BaseDeployer and expose category/ui_traits.",
                "type": "string"
              },
              "renderer": {
                "description": "Frontend renderer name (P2). Optional; verify types without a renderer fall back to the generic auto UI.",
                "type": "string"
              },
              "type": {
                "description": "Bare step type, namespaced to '<plugin-id>/<type>' on registration.",
                "type": "string"
              }
            },
            "required": [
              "type",
              "module",
              "category"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "renderers": {
          "description": "Frontend step renderers contributed by this plugin (P2; not yet consumed by the host).",
          "items": {
            "additionalProperties": true,
            "properties": {
              "entry": {
                "description": "Relative path to the renderer JS module.",
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "entry"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "description": {
      "type": "string"
    },
    "description_zh": {
      "type": "string"
    },
    "frontend": {
      "additionalProperties": true,
      "properties": {
        "css": {
          "type": "string"
        },
        "entry": {
          "description": "Relative path to the JS entry module (default frontend/index.js).",
          "type": "string"
        },
        "i18n": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Locale -> relative i18n JSON path.",
          "type": "object"
        },
        "type": {
          "description": "Frontend mount mode, e.g. 'overlay'.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "id": {
      "description": "Unique plugin identifier (directory name). Required by plugin_manager (plugin_manager.py:240).",
      "type": "string"
    },
    "min_app_version": {
      "description": "Minimum host app version required to load this plugin.",
      "type": "string"
    },
    "name": {
      "description": "Display name (EN).",
      "type": "string"
    },
    "name_zh": {
      "description": "Display name (ZH).",
      "type": "string"
    },
    "permissions": {
      "description": "Requested capabilities, e.g. ['network', 'websocket'].",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "settings": {
      "additionalProperties": true,
      "properties": {
        "schema": {
          "description": "Declarative settings form fields.",
          "items": {
            "additionalProperties": true,
            "properties": {
              "default": {},
              "description": {
                "type": "string"
              },
              "description_zh": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "label_zh": {
                "type": "string"
              },
              "options": {
                "type": "array"
              },
              "placeholder": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "type": {
                "description": "Field control type (text/password/select/checkbox/...).",
                "type": "string"
              }
            },
            "required": [
              "key",
              "type"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "version": {
      "description": "Plugin semantic version, e.g. 1.0.0.",
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "version"
  ],
  "title": "Plugin Manifest (plugin.json)",
  "type": "object"
}
