{
  "$defs": {
    "AutostartConfig": {
      "description": "Auto-start browser configuration for the deployed solution.\n\nWhen enabled and the target is a desktop-capable Linux device (RPi OS Desktop /\nUbuntu Desktop), deploy completion will install a `~/.config/autostart/*.desktop`\nentry on the remote host so the configured URL opens in a fullscreen/kiosk\nbrowser on every boot.\n\nNot applicable to headless devices (reCamera, server-only Ubuntu, etc.) — those\nwill be skipped with a warning rather than failing the deployment.",
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "mode": {
          "default": "fullscreen",
          "title": "Mode",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "user": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User"
        }
      },
      "title": "AutostartConfig",
      "type": "object"
    },
