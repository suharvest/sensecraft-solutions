# runtime.env — written by entrypoint.sh on first boot after probing
# the host. Sourced by pipeline.py via os.getenv(). Do NOT commit values
# here; this file is the template shipped with the image.
#
# After probing, real values look like:
#   ARM_PORT=/dev/ttyACM0
#   MIC_INDEX=2

ARM_PORT=
MIC_INDEX=
